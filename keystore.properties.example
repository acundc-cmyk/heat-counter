# Kopiere diese Datei zu "keystore.properties" und trage deine Werte ein,
# wenn du LOKAL (Android Studio) eine Release-APK signieren willst.
# Für den GitHub-Weg brauchst du diese Datei NICHT (dort kommen die Werte aus Secrets).
storeFile=keystore.jks
storePassword=DEIN_KEYSTORE_PASSWORT
keyAlias=heat
keyPassword=DEIN_SCHLUESSEL_PASSWORT
